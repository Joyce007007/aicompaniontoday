---
const { pick, vertical } = Astro.props;
if (!pick) return null;
const goUrl = `/go?offer=${pick.slug}&sid=sticky_${vertical}_${pick.slug}`;
---
<aside id="sticky-cta" class="fixed bottom-0 left-0 right-0 z-50 bg-white border-t-2 border-accent shadow-2xl md:hidden" style="padding-bottom: env(safe-area-inset-bottom);">
  <div class="flex items-center justify-between gap-3 px-4 py-3">
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2">
        <span class="text-[10px] font-bold uppercase tracking-wider bg-red-100 text-red-700 px-1.5 py-0.5 rounded">Editor's #1</span>
        <span class="text-[10px] text-ink-muted truncate">Free trial available</span>
      </div>
      <div class="text-sm font-bold text-primary truncate">{pick.name}</div>
    </div>
    <a href={goUrl} rel="nofollow sponsored noopener"
       class="shrink-0 bg-accent text-white px-5 py-2.5 rounded-lg font-bold text-sm shadow hover:bg-accent-dark whitespace-nowrap font-sans">
      Try Free →
    </a>
    <button id="sticky-close" aria-label="Close" class="shrink-0 text-ink-muted text-2xl leading-none px-1">×</button>
  </div>
</aside>
<script is:inline>
  (function() {
    var dismissed = sessionStorage.getItem('sticky_cta_dismissed');
    var el = document.getElementById('sticky-cta');
    if (!el) return;
    if (dismissed) { el.remove(); return; }
    var btn = document.getElementById('sticky-close');
    if (btn) btn.addEventListener('click', function() {
      sessionStorage.setItem('sticky_cta_dismissed', '1');
      el.remove();
    });
  })();
</script>
