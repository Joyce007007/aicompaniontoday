.tab-btn{padding:8px 18px;border-radius:999px;border:1px solid #e2e8f0;background:#fff;color:#1e293b;font-family:Inter,sans-serif;font-size:.85rem;font-weight:500;cursor:pointer;transition:all .15s}
.tab-btn.active{background:#1e293b;color:#fff;border-color:#1e293b}
