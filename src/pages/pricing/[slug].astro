---
import Base from '../../layouts/Base.astro';
import apps from '../../data/apps.json';
export function getStaticPaths(){ return apps.map((app)=>({params:{slug:app.slug}, props:{app}})); }
const { app } = Astro.props;
---
<Base title={`${app.name} Pricing: Free Trial, Subscription and Hidden Costs`} description={`Pricing notes for ${app.name}: free trial status, subscription evidence, token risks and alternatives.`}>
<section class="max-w-4xl mx-auto px-6 py-12"><nav class="text-sm text-ink-muted mb-6"><a href="/" class="hover:text-accent">Home</a> › Pricing › {app.name}</nav><h1 class="text-4xl font-bold text-primary">{app.name} pricing</h1><p class="text-xl text-ink-muted mt-4">{app.pricing}</p><div class="grid md:grid-cols-3 gap-4 mt-8"><div class="bg-white border rounded-2xl p-5"><strong>Free trial</strong><p class="text-sm text-ink-muted mt-2">{app.freeTrial}</p></div><div class="bg-white border rounded-2xl p-5"><strong>Commission path</strong><p class="text-sm text-ink-muted mt-2">{app.commission}</p></div><div class="bg-white border rounded-2xl p-5"><strong>Evidence level</strong><p class="text-sm text-ink-muted mt-2">Exact prices can vary by geo/platform; verify before publishing hard claims.</p></div></div><h2 class="text-2xl font-bold mt-10">Before paying</h2><ul class="list-disc pl-6 text-ink-muted mt-3 space-y-2"><li>Check monthly vs yearly renewal.</li><li>Check token/image/voice limits.</li><li>Check cancellation before subscribing.</li><li>Use privacy-friendly payment if discretion matters.</li></ul><a href={app.affiliateOffer ? `/go?offer=${app.affiliateOffer}&sid=pricing-${app.slug}` : app.url} rel="nofollow sponsored" class="inline-block mt-8 bg-accent text-white px-5 py-3 rounded-xl font-bold">Open {app.name}</a></section>
</Base>
