---
import Base from '../../layouts/Base.astro';
const title = 'Review Methodology';
const description = 'How AI Companion Today evaluates AI companion and AI girlfriend apps.';
---

<Base title={title} description={description}>
  <main class="container legal-page">
    <article>
      <h1>Review Methodology</h1>
      <p class="lead">AICT evaluates AI companion apps across conversation quality, memory, pricing, privacy controls, adult/NSFW transparency, media features, cancellation clarity and overall value. We separate broad AI companion authority pages from adult 18+ paid prelanders.</p>
      <section>
        <h2>What this means for visitors</h2>
        <ul>
          <li>AICT can earn affiliate commissions from partner links.</li>
          <li>Partner destinations, prices and policies can change outside our control.</li>
          <li>Adult-oriented pages are intended for 18+ visitors only.</li>
          <li>If a link destination looks wrong, contact us so we can fix it.</li>
        </ul>
      </section>
      <p><a href="/">← Back to AI Companion Today</a></p>
    </article>
  </main>
</Base>

<style>
  .legal-page { max-width: 820px; padding: 3rem 1rem; }
  .lead { font-size: 1.12rem; line-height: 1.7; color: #333; }
  li { margin: .5rem 0; }
</style>
