---
import Base from '../../layouts/Base.astro';
const title = 'How Affiliate Links Work';
const description = 'Plain-English explanation of AICT affiliate redirects and tracking.';
---

<Base title={title} description={description}>
  <main class="container legal-page">
    <article>
      <h1>How Affiliate Links Work</h1>
      <p class="lead">When you click a partner button, AICT may send you through a short internal /go route. That route records the click and forwards you to the partner site. We use this to understand which pages and offers are useful. We do not host checkout pages or control partner pricing.</p>
      <section>
        <h2>What this means for visitors</h2>
        <ul>
          <li>AICT can earn affiliate commissions from partner links.</li>
          <li>Partner destinations, prices and policies can change outside our control.</li>
          <li>Adult-oriented pages are intended for 18+ visitors only.</li>
          <li>If a link destination looks wrong, contact us so we can fix it.</li>
        </ul>
      </section>
      <p><a href="/">← Back to AI Companion Today</a></p>
    </article>
  </main>
</Base>

<style>
  .legal-page { max-width: 820px; padding: 3rem 1rem; }
  .lead { font-size: 1.12rem; line-height: 1.7; color: #333; }
  li { margin: .5rem 0; }
</style>
