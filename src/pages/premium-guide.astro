---
import Base from '../layouts/Base.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
---
<Base title="AI Girlfriend Setup Guide 2026 — Premium (€19)" description="Advanced 40-page guide: choose the right AI companion, optimize conversation memory, privacy-first setup, and avoid common pitfalls. €19 one-time." canonical="https://aicompaniontoday.com/premium-guide/">
  <section class="py-12 max-w-3xl mx-auto px-6">
    <span class="text-xs bg-accent text-white px-3 py-1 rounded-full font-sans font-semibold uppercase tracking-wider">Premium · 40 pages</span>
    <h1 class="text-4xl font-bold text-primary mt-4 mb-4 tracking-tight font-sans">AI Girlfriend Setup Guide 2026</h1>
    <p class="text-xl text-ink leading-relaxed mb-8">Everything you need to choose, set up and get real value from an AI companion in 2026 — in 40 pages, written by AICT Editorial Team after testing 25+ apps.</p>

    <div class="bg-surface-alt border-2 border-accent rounded-xl p-6 mb-8">
      <p class="text-lg font-sans"><strong>€19 one-time</strong> · Instant PDF download · 14-day refund</p>
      <a href="https://gumroad.com/l/aict-premium-guide-2026" rel="nofollow" class="inline-block mt-4 bg-accent text-white px-8 py-3 rounded-lg font-semibold hover:bg-accent-dark font-sans">Buy on Gumroad →</a>
      <p class="text-xs text-ink-muted mt-3 font-sans">Payment via Gumroad (Stripe/PayPal). You receive the PDF immediately after payment.</p>
