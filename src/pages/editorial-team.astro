---
import Base from '../layouts/Base.astro';
import authorsData from '../data/authors.json';

const title = "Editorial Team — AI Companion Today";
const description = "Meet the AICT editorial team. Sarah Chen (M.A. Psychology, Senior AI Companion Reviewer) and Marcus Rivera (Tech Journalist, AI Productivity Specialist).";
---

<Base title={title} description={description}>
  <main class="container">
    <article>
      <header>
        <h1>Editorial Team</h1>
        <p class="lead">AI Companion Today is produced by named experts with credentials in psychology, tech journalism, and AI product evaluation. Every article carries a byline. Mental health articles include a medical reviewer.</p>
      </header>

      {authorsData.authors.map((author) => (
        <section class="author" id={author.id}>
          <header class="author-header">
            <div class="info">
              <h2>{author.name}</h2>
              <p class="title">{author.title}</p>
              <p class="credentials"><em>{author.credentials}</em></p>
            </div>
          </header>

          <p class="bio">{author.bio}</p>

          <h3>Areas of expertise</h3>
          <ul class="expertise">
            {author.expertise.map((item) => <li>{item}</li>)}
          </ul>

          <h3>Verticals covered</h3>
          <p class="verticals">{author.verticals.join(' · ')}</p>

          <div class="social">
            {author.social.linkedin && <a href={author.social.linkedin} rel="noopener" target="_blank">LinkedIn</a>}
            {author.social.twitter && <a href={author.social.twitter} rel="noopener" target="_blank">Twitter / X</a>}
            {author.social.email && <a href={`mailto:${author.social.email}`}>Email</a>}
          </div>
        </section>
      ))}

      <section class="medical-board">
        <h2>Medical Advisory Board</h2>
        <p>{authorsData.medical_advisory_board.note}</p>
        <p><strong>Review process:</strong> {authorsData.medical_advisory_board.review_process}</p>
      </section>

      <section class="methodology-summary">
        <h2>Editorial Methodology</h2>
        <ul>
          <li><strong>Apps tested:</strong> {authorsData.editorial_methodology.apps_tested_total}+ AI companion apps</li>
          <li><strong>Total testing hours:</strong> {authorsData.editorial_methodology.total_testing_hours}+</li>
          <li><strong>Hours per app:</strong> {authorsData.editorial_methodology.testing_hours_per_app}</li>
          <li><strong>Scoring criteria:</strong> {authorsData.editorial_methodology.criteria_count} weighted dimensions</li>
        </ul>
        <p><a href="/methodology/">Read full methodology →</a></p>
      </section>
    </article>
  </main>
</Base>

<style>
  .lead { font-size: 1.2rem; color: #555; max-width: 700px; }
  .author { border-bottom: 1px solid #e0e0e0; padding: 2rem 0; }
  .author h2 { margin-bottom: 0.25rem; }
  .author .title { font-weight: 600; color: #2a5a8a; margin: 0; }
  .author .credentials { color: #666; margin-top: 0; }
  .bio { line-height: 1.6; }
  .expertise li { margin: 0.25rem 0; }
  .verticals { font-style: italic; color: #555; }
  .social { margin-top: 1rem; }
  .social a { margin-right: 1rem; color: #2a5a8a; }
  .medical-board { background: #f5f5f5; padding: 1rem; border-radius: 8px; margin: 2rem 0; }
  .methodology-summary { background: #fffaeb; padding: 1rem; border-radius: 8px; }
</style>
