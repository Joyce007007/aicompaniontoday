---
import Base from '../../layouts/Base.astro';
import apps from '../../data/apps.json';
export function getStaticPaths(){ return apps.map((app)=>({params:{slug:app.slug}, props:{app}})); }
const { app } = Astro.props;
const alternatives = (app.alternatives || []).map(slug => apps.find(a => a.slug === slug)).filter(Boolean);
---
<Base title={`Best ${app.name} Alternatives: AI Companion Apps Compared`} description={`Compare ${app.name} alternatives by pricing, free trial, privacy risk and affiliate availability.`}>
<section class="max-w-6xl mx-auto px-6 py-12">
<nav class="text-sm text-ink-muted mb-6"><a href="/" class="hover:text-accent">Home</a> › Alternatives › {app.name}</nav>
<h1 class="text-4xl font-bold text-primary">Best {app.name} alternatives</h1>
<p class="text-xl text-ink-muted mt-4">Use this page when {app.name} is too expensive, too restrictive, unavailable in your country, or not private enough.</p>
<div class="grid md:grid-cols-2 gap-5 mt-8">{alternatives.map((a) => <article class="bg-white border border-surface-border rounded-2xl p-6"><h2 class="text-2xl font-bold">{a.name}</h2><p class="text-ink-muted mt-2">{a.bestFor}</p><p class="text-sm mt-3"><strong>Pricing:</strong> {a.pricing}</p><div class="mt-5 flex gap-3 flex-wrap"><a href={`/apps/${a.slug}/`} class="border px-4 py-2 rounded-xl font-semibold">Review</a><a href={a.affiliateOffer ? `/go?offer=${a.affiliateOffer}&sid=alt-${app.slug}-${a.slug}` : a.url} rel="nofollow sponsored" class="bg-accent text-white px-4 py-2 rounded-xl font-semibold">Try →</a></div></article>)}</div>
<section class="bg-surface-alt border border-surface-border rounded-2xl p-6 mt-8"><h2 class="text-2xl font-bold">AICT verdict</h2><p class="text-ink-muted mt-2">Do not pick only from hype. Compare trial limits, cancellation, privacy, memory quality and whether the app has an affiliate/trial path that can be tracked cleanly.</p></section>
</section>
</Base>
