---
import Base from '../layouts/Base.astro';
---
<Base title="Partner with AI Companion Today — Sponsored Placements &amp; Pricing" description="AICT reaches engaged AI companion app buyers across 7 verticals. Sponsored reviews €200-2000, category takeovers, matcher quiz integration. Editorial firewall guaranteed." canonical="https://aicompaniontoday.com/partner/">
  <section class="py-16 max-w-4xl mx-auto px-6">
    <span class="text-xs bg-accent text-white px-3 py-1 rounded-full font-sans font-semibold uppercase tracking-wider">For brands &amp; networks</span>
    <h1 class="text-5xl font-bold text-primary mt-4 mb-6 tracking-tight font-sans">Partner with AI Companion Today</h1>
    <p class="text-xl text-ink leading-relaxed mb-10">AICT reaches an engaged, purchase-ready audience across seven AI verticals. Transparent pricing, mandatory sponsored labeling, editorial firewall guaranteed.</p>

    <h2 class="text-3xl font-bold text-primary mb-6 font-sans">Pricing transparent</h2>
    <div class="space-y-4 mb-12">
      <div class="bg-white border border-surface-border rounded-xl p-6">
        <h3 class="font-bold text-primary text-xl mb-2 font-sans">Sponsored review standard — <span class="text-accent">€200</span></h3>
        <p class="text-ink">Long-form editorial review (1500+ words) with our 12-criteria methodology applied. Clearly labeled sponsored. 4-week turnaround. Includes: dedicated post, Schema Review, 1 month featured in vertical sidebar.</p>
      </div>
      <div class="bg-white border border-surface-border rounded-xl p-6">
        <h3 class="font-bold text-primary text-xl mb-2 font-sans">Sponsored review premium — <span class="text-accent">€500</span></h3>
        <p class="text-ink">Standard + video review (60s) + social posts + featured top of vertical landing for 30 days + newsletter inclusion.</p>
      </div>
      <div class="bg-white border border-surface-border rounded-xl p-6">
        <h3 class="font-bold text-primary text-xl mb-2 font-sans">Category takeover — <span class="text-accent">€2000 / 30 days</span></h3>
        <p class="text-ink">Exclusive featured across a full vertical landing page for 30 days. Co-presented with max 1 competitor. Best for apps launching new tiers or geo expansion.</p>
      </div>
      <div class="bg-white border border-surface-border rounded-xl p-6">
        <h3 class="font-bold text-primary text-xl mb-2 font-sans">Affiliate network inclusion — <span class="text-accent">Revshare only</span></h3>
        <p class="text-ink">Add your program to our /go tracking layer. We route qualified traffic, you pay standard CPA. No upfront fee. Minimum CPA $20.</p>
      </div>
      <div class="bg-white border border-surface-border rounded-xl p-6">
        <h3 class="font-bold text-primary text-xl mb-2 font-sans">Matcher quiz integration — <span class="text-accent">€500 setup + revshare</span></h3>
        <p class="text-ink">Add your app to our <a href="/tools/matcher/" class="text-accent hover:underline">AI Companion Matcher</a>. Verified profile + scoring matrix. Setup fee €500, then standard CPA.</p>
      </div>
    </div>

    <h2 class="text-3xl font-bold text-primary mb-6 font-sans">Editorial firewall</h2>
    <div class="bg-surface-alt border border-surface-border rounded-xl p-6 mb-12">
      <ul class="space-y-3 text-ink">
        <li><strong>Rankings independent.</strong> Commission size never moves an app up/down our guides.</li>
        <li><strong>Paid content labeled.</strong> Clearly disclosed at top of article.</li>
        <li><strong>YMYL rules apply.</strong> Mental-health content follows strict safety guardrails.</li>
        <li><strong>No fabricated scores.</strong> Your score is your score.</li>
        <li><strong>Mutual approval.</strong> You review the draft, we keep final editorial control.</li>
      </ul>
    </div>

    <h2 class="text-3xl font-bold text-primary mb-6 font-sans">Contact</h2>
    <div class="bg-white border-2 border-primary rounded-xl p-8">
      <p class="text-lg text-ink leading-relaxed mb-6">Email us with placement ask, budget range, timing and product description. We reply within 3 business days.</p>
      <p class="text-xl font-mono mb-6"><a href="mailto:press@aicompaniontoday.com?subject=Partnership%20inquiry" class="text-accent hover:underline">press@aicompaniontoday.com</a></p>
      <p class="text-sm text-ink-muted font-sans">Include: <strong>company name</strong>, <strong>product URL</strong>, <strong>placement type</strong>, <strong>timeline</strong>, <strong>target geo</strong>, <strong>budget</strong>.</p>
    </div>
  </section>
</Base>
