---
import Base from '../../layouts/Base.astro';
import apps from '../../data/apps.json';
export function getStaticPaths(){ return apps.map((app)=>({params:{slug:app.slug}, props:{app}})); }
const { app } = Astro.props;
---
<Base title={`${app.name} Free Trial: What You Can Test Before Paying`} description={`Find whether ${app.name} has a free trial/free tier and what to test before upgrading.`}>
<section class="max-w-4xl mx-auto px-6 py-12"><nav class="text-sm text-ink-muted mb-6"><a href="/" class="hover:text-accent">Home</a> › Free trials › {app.name}</nav><h1 class="text-4xl font-bold text-primary">{app.name} free trial</h1><p class="text-xl text-ink-muted mt-4">{app.freeTrial}</p><h2 class="text-2xl font-bold mt-10">Test these before paying</h2><ol class="list-decimal pl-6 text-ink-muted mt-3 space-y-2"><li>Can it remember your preferences after 24h?</li><li>Are images/voice locked behind tokens?</li><li>Does the app support your country and payment method?</li><li>Can you delete account/conversations?</li><li>Is the paid CTA clear before checkout?</li></ol><a href={app.affiliateOffer ? `/go?offer=${app.affiliateOffer}&sid=trial-${app.slug}` : app.url} rel="nofollow sponsored" class="inline-block mt-8 bg-accent text-white px-5 py-3 rounded-xl font-bold">Check {app.name} trial →</a></section>
</Base>
