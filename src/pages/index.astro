---
import Base from '../layouts/Base.astro';
import { getAllPosts } from '../lib/ghost.js';
const posts = await getAllPosts();
---
<Base title="AI Companion Today — Independent Guide to AI Companion Apps" description="Honest, methodology-driven guides and reviews of AI companion apps across 7 verticals.">
  <section class="py-16 max-w-4xl mx-auto px-6 text-center">
    <h1 class="text-5xl font-bold text-primary mb-6 tracking-tight font-sans">The honest guide to AI companion apps</h1>
    <p class="text-xl text-ink leading-relaxed mb-8">Independent reviews and comparisons across companion, mental-health, seniors, language, productivity and gaming AI apps. Real testing, published methodology, no paid placements in rankings.</p>
    <div class="flex gap-4 justify-center">
      <a href="/best-ai-companion-apps-2026" class="inline-block bg-accent text-white px-8 py-3 rounded-lg font-semibold hover:bg-accent-dark font-sans">2026 Picks</a>
      <a href="/methodology" class="inline-block border border-primary text-primary px-8 py-3 rounded-lg font-semibold hover:bg-primary hover:text-white font-sans">How we test</a>
    </div>
  </section>
  <section class="bg-surface-alt py-16">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-primary mb-10 text-center font-sans">Latest guides & best-of</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.slice(0, 9).map(p => (
          <a href={`/${p.slug}`} class="block p-6 bg-white border border-surface-border rounded-xl hover:border-accent hover:shadow-lg transition">
            <div class="flex flex-wrap gap-2 mb-3">
              {(p.tags || []).slice(0, 2).map(t => <span class="text-xs bg-surface-alt text-ink-muted px-2 py-1 rounded">{t.name}</span>)}
            </div>
            <h3 class="font-bold text-primary text-lg mb-2 font-sans">{p.title}</h3>
            <p class="text-sm text-ink-muted leading-relaxed mb-3">{p.custom_excerpt || p.excerpt?.slice(0, 140)}</p>
            <time class="text-xs text-ink-subtle font-sans">{new Date(p.published_at).toLocaleDateString('en-US', {year:'numeric',month:'short',day:'numeric'})}</time>
          </a>
        ))}
      </div>
      {posts.length === 0 && <p class="text-center text-ink-muted">No posts yet. Check back soon.</p>}
    </div>
  </section>
  <section class="py-16 max-w-4xl mx-auto px-6">
    <div class="bg-white border-2 border-surface-border rounded-2xl p-8 text-center">
      <h2 class="text-2xl font-bold text-primary mb-4 font-sans">Reviewed by The AICT Editorial Team</h2>
      <p class="text-ink leading-relaxed mb-6">Every guide on AI Companion Today is produced under the editorial responsibility of our team, based on public features, pricing documentation, third-party reviews and direct testing. We never fabricate ratings or testimonials.</p>
    </div>
  </section>
</Base>
