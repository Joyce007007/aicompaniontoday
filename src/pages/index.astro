---
import Base from '../layouts/Base.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import { getAllPosts } from '../lib/ghost.js';
import { getCompanionNews } from '../lib/ai-news.js';

const posts = await getAllPosts();
const news = await getCompanionNews(6);
const buyerPosts = posts.filter(p => {
  const haystack = `${p.slug || ''} ${p.title || ''} ${(p.tags || []).map(t => t.slug || t.name || '').join(' ')}`.toLowerCase();
  const includesBuyerIntent = ['girlfriend', 'romance', 'candy', 'secrets', 'replika', 'privacy'].some(term => haystack.includes(term));
  const isDilution = ['mental-health', 'anxiety', 'teens', 'widows', 'seniors', 'language', 'productivity', 'jasper', 'talkpal'].some(term => haystack.includes(term));
  return includesBuyerIntent && !isDilution;
});

const moneyPages = [
  { name: 'Best AI girlfriend apps', url: '/best-ai-girlfriend-apps/', badge: 'Start here', desc: 'Candy AI, OurDream, Secrets, Kupid and Nomi ranked with scores, images and direct CTAs.' },
  { name: 'Free AI girlfriend apps', url: '/best-ai-girlfriend-free/', badge: 'Free trials', desc: 'Apps you can try before paying, with clear limits, pricing and privacy notes.' },
  { name: 'Candy AI honest review', url: '/candy-ai-honest-review-2026/', badge: 'Review', desc: 'Where Candy is strong, where it is weak, and who should choose another app.' },
  { name: 'Candy AI vs Secrets AI', url: '/candy-ai-vs-secrets-ai-2026/', badge: 'Comparison', desc: 'A direct choice page for users already close to paying.' },
  { name: 'Replika alternatives', url: '/replika-alternatives-2026/', badge: 'Alternatives', desc: 'Better options for romance, memory, privacy or roleplay depending on user intent.' },
  { name: 'AI companion privacy', url: '/ai-companion-privacy-compared-2026/', badge: 'Trust', desc: 'Privacy, data retention, billing discretion and safety criteria before subscribing.' }
];

const priorityOffers = [
  { name: 'Candy.ai', url: '/go?offer=candy-t1&sid=home_hot_candy', note: 'popular AI girlfriend offer' },
  { name: 'Secrets.ai', url: '/go?offer=secrets&sid=home_hot_secrets', note: 'romance chat alternative' },
  { name: 'GoLove.ai', url: '/go?offer=golove&sid=home_hot_golove', note: 'companion-first funnel' },
  { name: 'DreamGF', url: '/go?offer=dreamgf&sid=home_hot_dreamgf', note: 'AI girlfriend creation angle' }
];

const topApps = [
  { rank: 1, name: 'Candy.ai', bestFor: 'Realistic girlfriend chat + images', trial: 'Free preview', price: 'from about $12.99/mo', privacy: 'Standard', score: '4.6', url: '/go?offer=candy-t1&sid=home_rank_candy' },
  { rank: 2, name: 'Secrets.ai', bestFor: 'Romance chat + custom characters', trial: 'Free preview', price: 'from about $14.90/mo', privacy: 'Standard', score: '4.4', url: '/go?offer=secrets&sid=home_rank_secrets' },
  { rank: 3, name: 'GoLove.ai', bestFor: 'Fast companion funnel', trial: 'Free start', price: 'from about $9.99/mo', privacy: 'Standard', score: '4.2', url: '/go?offer=golove&sid=home_rank_golove' },
  { rank: 4, name: 'DreamGF', bestFor: 'Build-your-own AI girlfriend', trial: 'Free start', price: 'from about $9.99/mo', privacy: 'Standard', score: '4.1', url: '/go?offer=dreamgf&sid=home_rank_dreamgf' }
];

const trustStats = ['25+ apps reviewed', 'Pricing checked monthly', '12 comparison criteria', 'Affiliate links disclosed'];
const monitoredSources = ['TechCrunch', 'The Verge', 'VentureBeat', 'MIT Technology Review', 'AI Business', 'Wired', 'Business Insider', 'The Information'];

const itemListData = {
  name: 'AI girlfriend and companion money pages',
  items: moneyPages.map(v => ({ name: v.name, url: 'https://aicompaniontoday.com' + v.url }))
};
---
<Base title="Best AI Girlfriend Apps 2026 — AI Companion Today" description="Compare AI girlfriend and AI companion apps: Candy.ai, Secrets.ai, GoLove, DreamGF, Replika alternatives, pricing, privacy and free trials.">
  <SchemaOrg type="ItemList" data={itemListData} />

  <section class="py-16 max-w-5xl mx-auto px-6 text-center">
    <span class="inline-block bg-accent text-white px-4 py-2 rounded-full text-xs font-bold uppercase tracking-wider font-sans mb-5">2026 buyer guide · AI girlfriend apps · privacy-first comparisons</span>
    <h1 class="text-5xl font-bold text-primary mb-6 tracking-tight font-sans">Find the best AI girlfriend or companion app for your style</h1>
    <p class="text-xl text-ink leading-relaxed mb-8 max-w-3xl mx-auto">We compare Candy.ai, Secrets.ai, GoLove, DreamGF, Replika alternatives and privacy-focused AI companions. Start with the ranking, then choose by budget, realism, memory, privacy and free-trial options.</p>
    <div class="flex gap-4 justify-center flex-wrap">
      <a href="/romance/" class="inline-block bg-accent text-white px-8 py-3 rounded-lg font-semibold hover:bg-accent-dark font-sans">See best AI girlfriend apps →</a>
      <a href="/best-ai-girlfriend-free/" class="inline-block border border-primary text-primary px-8 py-3 rounded-lg font-semibold hover:bg-primary hover:text-white font-sans">Free AI girlfriend apps</a>
      <a href="/tools/matcher/" class="inline-block border border-surface-border text-ink px-8 py-3 rounded-lg font-semibold hover:border-accent font-sans">Take the matcher quiz</a>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3 mt-8 max-w-4xl mx-auto">
      {trustStats.map(item => (
        <div class="bg-white border border-surface-border rounded-lg px-4 py-3 text-sm font-semibold text-primary font-sans">{item}</div>
      ))}
    </div>
    <p class="text-xs text-ink-muted mt-5 font-sans">Affiliate disclosure: we may earn a commission when you click some app links. Apps cannot pay for a higher score, and rankings still use our published criteria.</p>
  </section>

  <section class="bg-white border-y border-surface-border py-12">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex items-end justify-between gap-4 flex-wrap mb-6">
        <div>
          <span class="text-xs bg-accent text-white px-3 py-1 rounded-full font-sans font-bold uppercase">Quick comparison</span>
          <h2 class="text-3xl font-bold text-primary mt-3 font-sans">Top AI girlfriend apps we would check first</h2>
          <p class="text-sm text-ink-muted mt-2 font-sans">A client should see the shortlist before clicking. Full notes, caveats and alternatives are inside the ranking.</p>
        </div>
        <a href="/romance/" class="text-accent font-semibold font-sans hover:underline">Open full ranking →</a>
      </div>
      <div class="overflow-x-auto border border-surface-border rounded-xl">
        <table class="w-full text-sm bg-white">
          <thead class="bg-surface-alt text-left text-primary font-sans">
            <tr>
              <th class="px-4 py-3">Rank</th>
              <th class="px-4 py-3">App</th>
              <th class="px-4 py-3">Best for</th>
              <th class="px-4 py-3">Trial</th>
              <th class="px-4 py-3">Price</th>
              <th class="px-4 py-3">Score</th>
              <th class="px-4 py-3">Action</th>
            </tr>
          </thead>
          <tbody>
            {topApps.map(app => (
              <tr class="border-t border-surface-border">
                <td class="px-4 py-4 font-bold text-accent font-sans">#{app.rank}</td>
                <td class="px-4 py-4 font-semibold text-primary font-sans">{app.name}</td>
                <td class="px-4 py-4 text-ink-muted font-sans">{app.bestFor}</td>
                <td class="px-4 py-4 font-sans">{app.trial}</td>
                <td class="px-4 py-4 font-sans">{app.price}</td>
                <td class="px-4 py-4 font-bold text-primary font-sans">{app.score}/5</td>
                <td class="px-4 py-4"><a href={app.url} rel="nofollow sponsored noopener" class="inline-block bg-accent text-white px-4 py-2 rounded font-semibold font-sans hover:bg-accent-dark">Try →</a></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="bg-white border-b border-surface-border py-8">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-xs text-ink-muted uppercase tracking-wider text-center mb-4 font-sans">Market sources monitored for pricing, product changes and AI safety news</p>
      <div class="flex flex-wrap justify-center gap-x-8 gap-y-2 text-ink-muted font-sans text-sm">
        {monitoredSources.map(name => <span>{name}</span>)}
      </div>
    </div>
  </section>

  <section class="bg-surface-alt py-16" id="money-pages">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-primary mb-3 text-center font-sans">Start with the pages most likely to help you choose</h2>
      <p class="text-center text-ink-muted mb-10 font-sans">AI Companion Today is now focused on buyer-intent AI girlfriend and companion comparisons.</p>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {moneyPages.map(v => (
          <a href={v.url} class="block p-6 bg-white border border-surface-border rounded-xl hover:border-accent hover:shadow-lg transition">
            <span class="text-xs bg-accent text-white px-2 py-1 rounded font-sans uppercase font-semibold">{v.badge}</span>
            <h3 class="font-bold text-primary text-lg mt-4 mb-2 font-sans">{v.name}</h3>
            <p class="text-sm text-ink-muted leading-relaxed">{v.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="bg-primary text-white rounded-2xl p-8 md:p-10">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-8">
          <div>
            <span class="text-xs bg-white text-primary px-3 py-1 rounded-full font-sans font-bold uppercase">Quick exits to tested offers</span>
            <h2 class="text-3xl font-bold mt-4 font-sans">Already ready to try an app?</h2>
            <p class="opacity-90 mt-2 font-sans">These links are tracked so we can learn which apps convert and improve the rankings.</p>
          </div>
          <a href="/advertising-disclosure/" class="text-sm underline opacity-90 font-sans">How affiliate links work</a>
        </div>
        <div class="grid md:grid-cols-4 gap-4">
          {priorityOffers.map(o => (
            <a href={o.url} rel="nofollow sponsored noopener" class="block bg-white text-primary rounded-xl p-5 hover:opacity-95 transition">
              <h3 class="font-bold font-sans mb-1">{o.name} →</h3>
              <p class="text-xs text-ink-muted font-sans">{o.note}</p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-gradient-to-r from-primary to-slate-700 text-white">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <span class="text-xs bg-accent text-white px-3 py-1 rounded-full font-sans font-semibold uppercase tracking-wider">Free tool · 2 min</span>
      <h2 class="text-3xl font-bold mt-4 mb-3 font-sans">Not sure which AI companion is right for you?</h2>
      <p class="text-lg opacity-90 mb-6 font-sans">Answer 7 quick questions and we'll match you with the best AI app for your goal, budget and style. No email required.</p>
      <a href="/tools/matcher/" class="inline-block bg-accent text-white px-8 py-3 rounded-lg font-semibold hover:bg-accent-dark font-sans">Take the quiz →</a>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-6">
      <div class="bg-gradient-to-br from-accent to-accent-dark text-white rounded-2xl p-10 text-center">
        <span class="text-xs bg-white text-accent px-3 py-1 rounded-full font-sans font-semibold uppercase tracking-wider">Premium · 40 pages PDF</span>
        <h2 class="text-3xl font-bold mt-4 mb-3 font-sans">Want the deeper version? AI Girlfriend Setup Guide 2026</h2>
        <p class="text-lg opacity-95 mb-6 font-sans max-w-2xl mx-auto">Choose the right app, optimize memory and tone, lock down your privacy, avoid the common pitfalls. Written after testing 25+ apps.</p>
        <a href="/premium-guide/" class="inline-block bg-white text-accent px-8 py-3 rounded-lg font-semibold hover:bg-surface-alt font-sans text-lg">Get the guide — €19 →</a>
        <p class="text-xs opacity-80 mt-4 font-sans">One-time · 14-day refund · Instant download via Gumroad</p>
      </div>
    </div>
  </section>

  {news.length > 0 && (
    <section class="py-16">
      <div class="max-w-6xl mx-auto px-6">
        <div class="flex items-end justify-between mb-8 flex-wrap gap-4">
          <div>
            <h2 class="text-3xl font-bold text-primary font-sans">AI market signals we monitor</h2>
            <p class="text-sm text-ink-muted mt-1 font-sans">Kept below the buyer tools so news does not distract visitors who are ready to compare apps.</p>
          </div>
          <a href="/news/" class="text-accent font-semibold font-sans hover:underline">More news →</a>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          {news.slice(0, 3).map(item => (
            <a href={item.url} target="_blank" rel="noopener" class="block p-5 bg-white border border-surface-border rounded-xl hover:border-accent transition">
              <div class="text-xs text-accent font-semibold font-sans mb-2">{item.source}</div>
              <h3 class="font-bold text-primary text-base mb-2 leading-snug font-sans">{item.title}</h3>
              {item.date && <time class="text-xs text-ink-subtle font-sans block mt-2">{new Date(item.date).toLocaleDateString('en-US', {year:'numeric',month:'short',day:'numeric'})}</time>}
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="bg-surface-alt py-16">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-primary mb-10 text-center font-sans">Buyer guides that match this niche</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {buyerPosts.slice(0, 6).map(p => (
          <a href={`/${p.slug}/`} class="block p-6 bg-white border border-surface-border rounded-xl hover:border-accent hover:shadow-lg transition">
            <div class="flex flex-wrap gap-2 mb-3">
              {(p.tags || []).slice(0, 2).map(t => <span class="text-xs bg-surface-alt text-ink-muted px-2 py-1 rounded font-sans">{t.name}</span>)}
            </div>
            <h3 class="font-bold text-primary text-lg mb-2 font-sans">{p.title}</h3>
            <p class="text-sm text-ink-muted leading-relaxed mb-3">{p.custom_excerpt || p.excerpt}</p>
            <time class="text-xs text-ink-subtle font-sans">{new Date(p.published_at).toLocaleDateString('en-US', {year:'numeric',month:'long',day:'numeric'})}</time>
          </a>
        ))}
      </div>
    </div>
  </section>

  <NewsletterForm />

  <section class="py-16 max-w-4xl mx-auto px-6">
    <div class="bg-white border-2 border-surface-border rounded-2xl p-8 text-center">
      <h2 class="text-2xl font-bold text-primary mb-4 font-sans">Reviewed by The AICT Editorial Team</h2>
      <p class="text-ink leading-relaxed">Every guide on AI Companion Today is produced under the editorial responsibility of our team, based on public features, pricing documentation, third-party reviews and direct testing.</p>
    </div>
  </section>
</Base>
