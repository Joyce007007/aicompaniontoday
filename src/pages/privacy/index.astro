---
import Base from '../../layouts/Base.astro';
const title = 'Privacy Policy';
const description = 'How AI Companion Today handles analytics, affiliate links, and visitor privacy.';
---

<Base title={title} description={description}>
  <main class="container legal-page">
    <article>
      <h1>Privacy Policy</h1>
      <p class="lead">We keep AI Companion Today lightweight. We do not sell personal profiles. Affiliate clicks may be routed through partner tracking links so we can measure commissions. Partner sites have their own privacy policies and payment flows.</p>
      <section>
        <h2>What this means for visitors</h2>
        <ul>
          <li>AICT can earn affiliate commissions from partner links.</li>
          <li>Partner destinations, prices and policies can change outside our control.</li>
          <li>Adult-oriented pages are intended for 18+ visitors only.</li>
          <li>If a link destination looks wrong, contact us so we can fix it.</li>
        </ul>
      </section>
      <p><a href="/">← Back to AI Companion Today</a></p>
    </article>
  </main>
</Base>

<style>
  .legal-page { max-width: 820px; padding: 3rem 1rem; }
  .lead { font-size: 1.12rem; line-height: 1.7; color: #333; }
  li { margin: .5rem 0; }
</style>
