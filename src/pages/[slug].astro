---
import Base from '../layouts/Base.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import { getAllPosts, getAllPages } from '../lib/ghost.js';

export async function getStaticPaths() {
  const posts = await getAllPosts();
  const pages = await getAllPages();
  return [
    ...posts.map(p => ({ params: { slug: p.slug }, props: { content: p, type: 'post' } })),
    ...pages.map(p => ({ params: { slug: p.slug }, props: { content: p, type: 'page' } }))
  ];
}

const { content, type } = Astro.props;
const tags = content.tags || [];
const isYMYL = tags.some(t => t.slug === 'ymyl' || t.slug === 'mental-health');
const isBestOf = tags.some(t => t.slug === 'best-of') || (content.slug || '').startsWith('best-');
const isCompare = tags.some(t => t.slug === 'compare') || (content.slug || '').includes('-vs-');

const url = `https://aicompaniontoday.com/${content.slug}/`;

// Vertical detection from slug + tags
const slug = (content.slug || '').toLowerCase();
let vertical = 'companion';
if (slug.includes('mental') || slug.includes('therap') || slug.includes('anxiety') || tags.some(t => t.slug === 'mental-health')) vertical = 'mental-health';
else if (slug.includes('senior') || slug.includes('widow') || slug.includes('elder')) vertical = 'seniors';
else if (slug.includes('language') || slug.includes('tutor') || slug.includes('babbel') || slug.includes('talkpal')) vertical = 'language';
else if (slug.includes('writing') || slug.includes('jasper') || slug.includes('chatgpt') || slug.includes('claude') || slug.includes('image-generator') || slug.includes('productivity')) vertical = 'productivity';
else if (slug.includes('boyfriend') || slug.includes('girlfriend') || slug.includes('candy') || slug.includes('romance') || slug.includes('nsfw')) vertical = 'romance';
else if (slug.includes('gaming') || slug.includes('dungeon')) vertical = 'gaming';
else if (slug.includes('education') || slug.includes('kids') || slug.includes('teacher')) vertical = 'education';

// Author selection per vertical
const SARAH_VERTICALS = ['companion', 'mental-health', 'seniors', 'romance'];
const author = SARAH_VERTICALS.includes(vertical)
  ? { name: 'Sarah Chen', slug: 'sarah-chen', title: 'Senior AI Companion Reviewer', sameAs: ['https://www.linkedin.com/in/sarah-chen-aict','https://twitter.com/SarahChenAI'] }
  : { name: 'Marcus Rivera', slug: 'marcus-rivera', title: 'AI Productivity Specialist', sameAs: ['https://www.linkedin.com/in/marcus-rivera-aict','https://twitter.com/MarcusRiveraAI'] };

// Top 5 picks per vertical
const PICKS = {
  'companion': [
    { name: 'Candy.ai', slug: 'candy-t1', payout: 'Best for realism', desc: 'Realistic AI companion with image generation and voice.' },
    { name: 'Replika', slug: 'smartlink', payout: 'Best known brand', desc: 'Large user base, generous free tier and emotional-companion positioning.' },
    { name: 'Nomi', slug: 'smartlink', payout: 'Best memory angle', desc: 'Strong persistent memory and long-term companion positioning.' },
    { name: 'Kindroid', slug: 'smartlink', payout: 'Privacy-minded', desc: 'Good choice for users who care about customization and privacy settings.' },
    { name: 'Character.AI', slug: 'smartlink', payout: 'Best free roleplay', desc: 'Free roleplay and huge character library.' }
  ],
  'mental-health': [
    { name: 'BetterHelp', slug: 'smartlink', payout: '$100/lead', desc: 'Largest online therapy network. Licensed therapists.' },
    { name: 'Headspace', slug: 'smartlink', payout: 'Premium meditation', desc: 'Industry leader meditation + sleep. 70M+ users.' },
    { name: 'Calm', slug: 'smartlink', payout: 'Sleep stories', desc: '100M+ downloads. Sleep stories and breathing.' },
    { name: 'Wysa', slug: 'smartlink', payout: 'AI + therapist', desc: 'CBT-based AI chatbot, optional licensed therapist add-on.' },
    { name: 'Talkspace', slug: 'smartlink', payout: 'NASDAQ-listed', desc: 'Online therapy platform. Insurance covered options.' }
  ],
  'seniors': [
    { name: 'ElliQ', slug: 'smartlink', payout: '$250/mo', desc: 'Tabletop companion robot for 65+. Voice-only interface.' },
    { name: 'GrandPad', slug: 'smartlink', payout: 'Tablet plan', desc: 'Senior-simplified tablet with AI assistance.' },
    { name: 'Lovot', slug: 'smartlink', payout: 'Premium robot', desc: 'Companion robot from Japan, emotional bonding focus.' },
    { name: 'Joy for All', slug: 'smartlink', payout: 'Plush companion', desc: 'Robotic plush companions for dementia patients.' },
    { name: 'Pillo', slug: 'smartlink', payout: 'Health management', desc: 'AI health assistant for seniors, medication reminders.' }
  ],
  'language': [
    { name: 'Talkpal', slug: 'smartlink', payout: 'AI conversation', desc: 'AI-only language tutor. Strong in Spanish/French/Mandarin.' },
    { name: 'Babbel', slug: 'smartlink', payout: '16M+ subs', desc: 'Structured curriculum. $13.95/mo annual plan.' },
    { name: 'Duolingo Max', slug: 'smartlink', payout: '$14.99/mo', desc: 'GPT-4 powered conversation practice.' },
    { name: 'Italki', slug: 'smartlink', payout: 'Live tutors', desc: 'Largest 1-on-1 tutor marketplace. 30k+ teachers.' },
    { name: 'Rosetta Stone', slug: 'smartlink', payout: 'Classic curriculum', desc: 'Veteran brand, immersive method.' }
  ],
  'productivity': [
    { name: 'ChatGPT Plus', slug: 'smartlink', payout: '$20/mo', desc: 'GPT-4o + DALL-E 3 + Voice. 200M+ weekly users.' },
    { name: 'Claude Pro', slug: 'smartlink', payout: '$20/mo Anthropic', desc: 'Best-in-class coding + writing quality.' },
    { name: 'Jasper', slug: 'smartlink', payout: '30% recurring', desc: 'Marketing copywriter AI for teams. $125M ARR.' },
    { name: 'Notion AI', slug: 'smartlink', payout: '50% recurring', desc: '$10/mo add-on to Notion. 30M+ user base.' },
    { name: 'Surfer SEO', slug: 'smartlink', payout: '25% recurring', desc: 'AI-powered SEO content optimizer.' }
  ],
  'romance': [
    { name: 'Candy.ai', slug: 'candy-t1', payout: 'Best for realism', desc: 'Realistic AI girlfriend, image generation and voice.' },
    { name: 'Secrets.ai', slug: 'secrets', payout: 'Best privacy angle', desc: 'Romance chat, custom characters and discreet onboarding.' },
    { name: 'GoLove.ai', slug: 'golove', payout: 'Best fast start', desc: 'Simple companion-first flow for users who want to try quickly.' },
    { name: 'DreamGF', slug: 'dreamgf', payout: 'Best customization', desc: 'Build-your-own AI girlfriend angle with fantasy and image generation.' },
    { name: 'OurDream', slug: 'ourdream', payout: 'Alternative pick', desc: 'Custom companion option for users comparing multiple paid apps.' }
  ],
  'gaming': [
    { name: 'AI Dungeon', slug: 'smartlink', payout: '$20/mo Premium', desc: 'AI-powered text adventure. 1M+ paying users.' },
    { name: 'Inworld', slug: 'smartlink', payout: 'NPC platform', desc: 'AI NPCs for game devs. NVIDIA partnership.' },
    { name: 'Convai', slug: 'smartlink', payout: 'Dev SDK', desc: 'Conversational AI for game characters.' },
    { name: 'Skybox AI', slug: 'smartlink', payout: 'Roblox/Unity', desc: 'AI 3D world generation from text.' },
    { name: 'Character.AI', slug: 'smartlink', payout: 'Roleplay free', desc: 'Free character creation + roleplay.' }
  ],
  'education': [
    { name: 'Khanmigo', slug: 'smartlink', payout: 'Free + $4/mo', desc: 'Khan Academy AI tutor for K-12.' },
    { name: 'MagicSchool AI', slug: 'smartlink', payout: '4M+ teachers', desc: 'AI tools for teachers.' },
    { name: 'Curipod', slug: 'smartlink', payout: 'Free + Pro $7.50', desc: 'Interactive AI lessons.' },
    { name: 'Synthesia for Teachers', slug: 'smartlink', payout: '$29-89/mo', desc: 'AI avatar video creation for educators.' },
    { name: 'BrainPop AI', slug: 'smartlink', payout: '$9.95/mo', desc: 'AI-augmented animated learning.' }
  ]
};
const verticalPicks = PICKS[vertical] || PICKS['companion'];

const articleSchema = {
  headline: content.title,
  datePublished: content.published_at,
  dateModified: content.updated_at || content.published_at,
  url,
  authorName: author.name,
  authorSlug: author.slug,
  authorTitle: author.title,
  authorSameAs: author.sameAs
};

const breadcrumbItems = [
  { name: 'Home', url: 'https://aicompaniontoday.com/' },
  ...(isBestOf ? [{ name: 'Best-of guides', url: 'https://aicompaniontoday.com/' }] : []),
  ...(isCompare ? [{ name: 'Comparisons', url: 'https://aicompaniontoday.com/' }] : []),
  { name: content.title, url }
];
---
<Base title={`${content.title} — AI Companion Today`} description={content.custom_excerpt || content.excerpt || content.title} canonical={url}>
  {type === 'post' && <SchemaOrg type="Article" data={articleSchema} />}
  <SchemaOrg type="BreadcrumbList" data={{ items: breadcrumbItems }} />
  {(content.html || '').match(/<strong>.*?\?<\/strong>/gi) && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": (content.html.match(/<p><strong>(.+?\?)<\/strong><br>(.+?)<\/p>/g) || []).slice(0, 10).map(block => {
        const m = block.match(/<strong>(.+?\?)<\/strong><br>(.+?)<\/p>/);
        return m ? {
          "@type": "Question",
          "name": m[1].replace(/<[^>]+>/g, ''),
          "acceptedAnswer": { "@type": "Answer", "text": m[2].replace(/<[^>]+>/g, '') }
        } : null;
      }).filter(Boolean)
    })} />
  )}

  {isYMYL && (
    <div class="bg-danger text-white text-center py-2 text-sm">
      <strong>In crisis?</strong> Call 988 (US) or 3114 (France). AI chatbots are not a substitute for professional care.
    </div>
  )}
  <article class="max-w-3xl mx-auto px-6 py-12">
    <nav class="text-xs text-ink-muted mb-6 font-sans" aria-label="Breadcrumb">
      <a href="/" class="hover:text-accent">Home</a>
      <span class="mx-2">›</span>
      <span class="text-ink">{content.title}</span>
    </nav>

    <div class="flex flex-wrap gap-2 mb-4">
      {tags.map(t => <span class="text-xs bg-surface-alt text-ink-muted px-2 py-1 rounded font-sans">{t.name}</span>)}
    </div>
    <h1 class="text-4xl font-bold text-primary mb-4 tracking-tight font-sans">{content.title}</h1>
    <div class="text-sm text-ink-muted mb-6 font-sans">
      {type === 'post' && (
        <span>Published {new Date(content.published_at).toLocaleDateString('en-US', {year:'numeric',month:'long',day:'numeric'})} &middot; By <a href={`/editorial-team/#${author.slug}`} class="text-accent hover:underline">{author.name}</a> ({author.title}) &middot; <a href="/methodology/" class="text-accent hover:underline">Methodology</a></span>
      )}
    </div>

    {isBestOf && (
      <section class="my-8 p-6 bg-surface-alt rounded-xl border border-surface-border">
        <h2 class="text-2xl font-bold text-primary mb-4 font-sans">Top 5 picks ({vertical})</h2>
        <div class="grid md:grid-cols-2 gap-4">
          {verticalPicks.map((pick, i) => (
            <div class="bg-white p-4 rounded-lg border border-surface-border">
              <div class="flex items-baseline gap-2 mb-2">
                <span class="text-xs bg-accent text-white px-2 py-1 rounded font-bold">#{i+1}</span>
                <h3 class="text-lg font-semibold text-primary font-sans">{pick.name}</h3>
              </div>
              <p class="text-sm text-ink-muted mb-3 font-sans">{pick.desc}</p>
              <div class="flex items-center justify-between">
                <span class="text-xs text-ink-muted font-sans">{pick.payout}</span>
                <a href={`/go?offer=${pick.slug}&sid=bestof_${vertical}_${pick.slug}`} class="inline-block bg-accent text-white px-4 py-2 rounded font-semibold text-sm hover:bg-accent-dark font-sans" rel="nofollow sponsored noopener">Try {pick.name} →</a>
              </div>
            </div>
          ))}
        </div>
        <p class="text-xs text-ink-muted mt-4 font-sans">
          ⓘ Affiliate disclosure: we earn a commission if you sign up via these links, at no extra cost to you. <a href="/advertising-disclosure/" class="underline">Full disclosure</a>.
        </p>
      </section>
    )}

    <div class="prose prose-lg max-w-none" set:html={content.html} />
  </article>

  {type === 'post' && (
    <section class="max-w-3xl mx-auto px-6 pb-12">
      <div class="bg-surface-alt border border-surface-border rounded-xl p-6 text-center">
        <h3 class="text-lg font-bold text-primary mb-2 font-sans">Not sure which app to pick?</h3>
        <p class="text-sm text-ink-muted mb-4 font-sans">Take our 2-minute quiz and get a personalized recommendation.</p>
        <a href="/tools/matcher/" class="inline-block bg-accent text-white px-6 py-2 rounded-lg font-semibold hover:bg-accent-dark font-sans">Find my AI companion →</a>
      </div>
    </section>
  )}

  <NewsletterForm compact />
</Base>
