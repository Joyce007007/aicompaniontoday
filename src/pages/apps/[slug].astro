---
import Base from '../../layouts/Base.astro';
import apps from '../../data/apps.json';
export function getStaticPaths() {
  return apps.map((app) => ({ params: { slug: app.slug }, props: { app } }));
}
const { app } = Astro.props;
const ctaHref = app.affiliateOffer ? `/go?offer=${app.affiliateOffer}&sid=app-${app.slug}` : app.url;
const ctaLabel = app.affiliateOffer ? `Try ${app.name}` : `Visit ${app.name}`;
const related = (app.alternatives || []).map(slug => apps.find(a => a.slug === slug)).filter(Boolean);
---
<Base title={`${app.name} Review: Pricing, Alternatives, Privacy & Free Trial`} description={`Proof-first ${app.name} review for AI companion buyers: pricing, free trial, privacy risks, alternatives and monetization notes.`}>
  <section class="max-w-6xl mx-auto px-6 py-12">
    <nav class="text-sm text-ink-muted mb-6"><a href="/" class="hover:text-accent">Home</a> › <a href="/apps/" class="hover:text-accent">Apps</a> › {app.name}</nav>
    <div class="grid lg:grid-cols-[1.2fr_.8fr] gap-8 items-start">
      <article class="bg-white border border-surface-border rounded-2xl p-8 shadow-sm">
        <p class="text-sm uppercase tracking-wide text-accent font-bold">AICT app database</p>
        <h1 class="text-4xl font-bold text-primary mt-2">{app.name} review</h1>
        <p class="text-xl text-ink-muted mt-4">{app.bestFor}</p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href={ctaHref} rel="nofollow sponsored" class="bg-accent text-white px-5 py-3 rounded-xl font-bold hover:opacity-90">{ctaLabel} →</a>
          <a href={`/alternatives/${app.slug}/`} class="border border-surface-border px-5 py-3 rounded-xl font-bold hover:border-accent">See alternatives</a>
          <a href={`/pricing/${app.slug}/`} class="border border-surface-border px-5 py-3 rounded-xl font-bold hover:border-accent">Pricing notes</a>
        </div>
        <h2 class="text-2xl font-bold mt-10 mb-3">What it is</h2>
        <p class="text-ink-muted">{app.name} is tracked by AICT as a <strong>{app.category}</strong> product. This page is generated from the AICT structured app database so pricing, affiliate status, privacy notes and alternatives can be updated consistently.</p>
        <h2 class="text-2xl font-bold mt-10 mb-3">Features checked</h2>
        <ul class="grid sm:grid-cols-2 gap-3">{app.features.map((f) => <li class="bg-surface-alt rounded-xl p-4 border border-surface-border">✓ {f}</li>)}</ul>
        <h2 class="text-2xl font-bold mt-10 mb-3">Traffic / revenue evidence</h2>
        <div class="space-y-3 text-ink-muted">
          <p><strong>Traffic proof:</strong> {app.trafficProof}</p>
          <p><strong>Revenue proof:</strong> {app.revenueProof}</p>
          <p><strong>Top countries:</strong> {app.topCountries}</p>
        </div>
        <h2 class="text-2xl font-bold mt-10 mb-3">Risks before paying</h2>
        <ul class="list-disc pl-6 text-ink-muted space-y-2">{app.risks.map((r) => <li>{r}</li>)}</ul>
      </article>
      <aside class="bg-surface-alt border border-surface-border rounded-2xl p-6 sticky top-24">
        <h2 class="text-xl font-bold text-primary">Quick facts</h2>
        <dl class="mt-4 space-y-3 text-sm">
          <div><dt class="font-bold">Category</dt><dd>{app.category}</dd></div>
          <div><dt class="font-bold">Pricing</dt><dd>{app.pricing}</dd></div>
          <div><dt class="font-bold">Free trial</dt><dd>{app.freeTrial}</dd></div>
          <div><dt class="font-bold">Affiliate</dt><dd>{app.affiliateNetwork || 'No public affiliate verified'}</dd></div>
          <div><dt class="font-bold">Commission</dt><dd>{app.commission}</dd></div>
        </dl>
        <a href={ctaHref} rel="nofollow sponsored" class="mt-6 block text-center bg-primary text-white px-4 py-3 rounded-xl font-bold">Open offer</a>
      </aside>
    </div>
    <section class="mt-10"><h2 class="text-2xl font-bold mb-4">Related alternatives</h2><div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">{related.map((r) => <a class="bg-white border border-surface-border rounded-xl p-4 hover:border-accent" href={`/apps/${r.slug}/`}><strong>{r.name}</strong><br/><span class="text-sm text-ink-muted">{r.bestFor}</span></a>)}</div></section>
  </section>
</Base>
