---
import Base from '../../layouts/Base.astro';
const title = "Terms of Use \u2014 AI Companion Today";
const description = "AI Companion Today provides informational comparisons and affiliate links. We do not operate partner products, payment pages or support systems. Use partner platforms according to their own terms and only if you meet their age requirements.";
---

<Base title={title} description={description}>
  <main class="container" style="max-width:860px;padding:3rem 1rem;">
    <article>
      <h1>Terms of Use</h1>
      <p class="lead">AI Companion Today provides informational comparisons and affiliate links. We do not operate partner products, payment pages or support systems. Use partner platforms according to their own terms and only if you meet their age requirements.</p>
      <section>
        <h2>Current recommendation</h2>
        <p>AI Companion Today is consolidating this page into the monetization and review system. For the strongest adult romance comparison, start with the romance guide.</p>
        <p><a href="/romance/">Read the AI girlfriend comparison guide →</a></p>
      </section>
      <section>
        <h2>Affiliate disclosure</h2>
        <p>We may earn a commission when you click partner links. Partner prices, offers and policies can change outside our control.</p>
      </section>
    </article>
  </main>
</Base>
