---
interface Props { title: string; description: string; canonical?: string; ogImage?: string; }
const { title, description, canonical, ogImage } = Astro.props;
import SchemaOrg from '../components/SchemaOrg.astro';
const GA4_ID = import.meta.env.GA4_ID || '';
const GSC_VERIFY = import.meta.env.GSC_VERIFY || '';
const SITE_URL = 'https://aicompaniontoday.com';
const canonicalUrl = canonical || `${SITE_URL}${Astro.url.pathname}`;
const ogImageUrl = ogImage || `${SITE_URL}/og-default.png`;
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{title}</title>
<meta name="description" content={description}>
<link rel="canonical" href={canonicalUrl}>
<meta property="og:title" content={title}>
<meta property="og:description" content={description}>
<meta property="og:type" content="website">
<meta property="og:url" content={canonicalUrl}>
<meta property="og:site_name" content="AI Companion Today">
<meta property="og:image" content={ogImageUrl}>
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content={title}>
<meta name="twitter:description" content={description}>
<meta name="twitter:image" content={ogImageUrl}>
<meta name="twitter:site" content="@SarahChenAI">
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<link rel="alternate" type="application/rss+xml" title="AI Companion Today" href="/rss.xml">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Source+Serif+Pro:wght@400;600&display=swap" rel="stylesheet">
<SchemaOrg type="Organization" />
<SchemaOrg type="WebSite" />
{GSC_VERIFY && <meta name="google-site-verification" content={GSC_VERIFY} />}
{GA4_ID && (
  <>
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA4_ID}`}></script>
    <script is:inline define:vars={{GA4_ID}}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag("js", new Date());
      gtag("config", GA4_ID, {anonymize_ip: true});
    </script>
  </>
)}
</head>
<body class="min-h-screen flex flex-col">
<header class="border-b border-surface-border bg-white sticky top-0 z-20">
  <nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="text-xl font-bold text-primary tracking-tight">AI Companion Today</a>
    <div class="hidden md:flex gap-5 text-sm font-sans">
      <a href="/romance/" class="text-accent font-semibold">AI Girlfriend Apps</a>
      <a href="/best-ai-girlfriend-free/" class="text-ink hover:text-accent">Free Trials</a>
      <a href="/candy-ai-honest-review-2026/" class="text-ink hover:text-accent">Candy Review</a>
      <a href="/candy-ai-vs-secrets-ai-2026/" class="text-ink hover:text-accent">Candy vs Secrets</a>
      <a href="/replika-alternatives-2026/" class="text-ink hover:text-accent">Replika Alternatives</a>
      <a href="/ai-companion-privacy-compared-2026/" class="text-ink hover:text-accent">Privacy</a>
      <a href="/tools/matcher/" class="text-accent font-semibold">Matcher</a>
      <a href="/methodology/" class="text-ink-muted hover:text-accent">Methodology</a>
    </div>
  </nav>
</header>

<main class="flex-1">
<slot />
</main>

<!-- Pageview tracking beacon (POST /pv) -->
<script is:inline>
(function(){
  try {
    const sid = (function(){
      let s = sessionStorage.getItem('aict_sid');
      if (!s) { s = Math.random().toString(36).slice(2,10) + Date.now().toString(36); sessionStorage.setItem('aict_sid', s); }
      return s;
    })();
    const params = new URLSearchParams(location.search);
    const payload = JSON.stringify({
      sid: sid,
      path: location.pathname + location.search,
      referrer: document.referrer || '',
      utm_source: params.get('utm_source') || '',
      utm_medium: params.get('utm_medium') || '',
      utm_campaign: params.get('utm_campaign') || ''
    });
    if (navigator.sendBeacon) {
      navigator.sendBeacon('/pv', new Blob([payload], {type:'application/json'}));
    } else {
      fetch('/pv', {method:'POST', headers:{'Content-Type':'application/json'}, body: payload, keepalive: true}).catch(()=>{});
    }
  } catch(e) {}
})();
</script>

<footer class="border-t border-surface-border bg-surface-alt mt-16">
  <div class="max-w-6xl mx-auto px-6 py-8 text-sm text-ink-muted font-sans flex flex-wrap gap-4">
    <a href="/about/" class="hover:text-accent">About</a>
    <a href="/contact/" class="hover:text-accent">Contact</a>
    <a href="/privacy/" class="hover:text-accent">Privacy</a>
    <a href="/terms/" class="hover:text-accent">Terms</a>
    <a href="/advertising-disclosure/" class="hover:text-accent">Advertising Disclosure</a>
    <a href="/methodology/" class="hover:text-accent">Methodology</a>
    <a href="/disclaimer-mental-health/" class="hover:text-accent">Mental Health Disclaimer</a>
    <a href="/tools/matcher/" class="hover:text-accent">AI Matcher</a>
    <span class="ml-auto">© 2026 AI Companion Today</span>
  </div>
</footer>

<!-- EVADAV push: ONLY on /romance/ (NSFW) — coupé du reste pour ne pas cannibaliser /go affiliate -->
{Astro.url.pathname.startsWith("/romance") && (
  <script async src="https://esquelbqu.com/ntfc.php?p=3093462" data-site-id="3093462" data-init="auto" id="evadav_push_init"></script>
)}

<script is:inline>
(function(){
  const forced = new URLSearchParams(location.search).get('lang') || localStorage.getItem('aict_lang');
  const navLang = (navigator.language || '').toLowerCase();
  const langs = (navigator.languages || []).join(',').toLowerCase();
  const tz = Intl.DateTimeFormat().resolvedOptions().timeZone || '';
  const locale = forced || (navLang.startsWith('ja') || langs.includes('ja') || tz === 'Asia/Tokyo' ? 'ja' : (navLang.startsWith('pt') || langs.includes('pt-br') || tz.includes('Sao_Paulo') ? 'pt-br' : 'en'));
  if (!['ja','pt-br'].includes(locale)) return;
  localStorage.setItem('aict_lang', locale);
  document.documentElement.lang = locale;
  const dict = {
    'ja': {
      label: '日本語表示を自動適用しました', keep: 'English',
      'AI Girlfriend Apps':'AI彼女アプリ','Free Trials':'無料トライアル','Candy Review':'Candyレビュー','Candy vs Secrets':'Candy vs Secrets','Replika Alternatives':'Replika代替','Privacy':'プライバシー','Matcher':'診断','Methodology':'評価方法',
      'Find the best AI girlfriend or companion app for your style':'あなたに合うAI彼女・AIコンパニオンアプリを見つける',
      'See best AI girlfriend apps →':'AI彼女ランキングを見る →','Free AI girlfriend apps':'無料AI彼女アプリ','Take the matcher quiz':'2分診断を始める',
      '25+ apps reviewed':'25以上のアプリを調査','Pricing checked monthly':'価格を毎月確認','12 comparison criteria':'12項目で比較','Affiliate links disclosed':'広告リンクを明記',
      'Top AI girlfriend apps we would check first':'最初に確認すべきAI彼女アプリ','Quick comparison':'クイック比較','Open full ranking →':'完全ランキングを見る →',
      'Rank':'順位','App':'アプリ','Best for':'おすすめ用途','Trial':'無料枠','Price':'価格','Score':'スコア','Action':'アクション','Try →':'試す →',
      'Already ready to try an app?':'すぐ試したいですか？','Not sure which AI companion is right for you?':'どのAIコンパニオンが合うか迷っていますか？','Take the quiz →':'診断を始める →',
      'Best AI girlfriend apps in 2026, ranked by real buying criteria':'2026年版ベストAI彼女アプリ：購入前に見るべき基準でランキング'
    },
    'pt-br': {
      label: 'Português do Brasil aplicado automaticamente', keep: 'English',
      'AI Girlfriend Apps':'Apps de namorada IA','Free Trials':'Testes grátis','Candy Review':'Review Candy','Candy vs Secrets':'Candy vs Secrets','Replika Alternatives':'Alternativas ao Replika','Privacy':'Privacidade','Matcher':'Quiz','Methodology':'Metodologia',
      'Find the best AI girlfriend or companion app for your style':'Encontre o melhor app de namorada IA ou companion para o seu estilo',
      'See best AI girlfriend apps →':'Ver melhores apps de namorada IA →','Free AI girlfriend apps':'Apps grátis de namorada IA','Take the matcher quiz':'Fazer o quiz',
      '25+ apps reviewed':'25+ apps analisados','Pricing checked monthly':'Preços verificados mensalmente','12 comparison criteria':'12 critérios de comparação','Affiliate links disclosed':'Links afiliados informados',
      'Top AI girlfriend apps we would check first':'Apps de namorada IA que eu olharia primeiro','Quick comparison':'Comparação rápida','Open full ranking →':'Abrir ranking completo →',
      'Rank':'Rank','App':'App','Best for':'Melhor para','Trial':'Teste','Price':'Preço','Score':'Nota','Action':'Ação','Try →':'Testar →',
      'Already ready to try an app?':'Já quer testar um app?','Not sure which AI companion is right for you?':'Não sabe qual companion IA combina com você?','Take the quiz →':'Fazer o quiz →',
      'Best AI girlfriend apps in 2026, ranked by real buying criteria':'Melhores apps de namorada IA em 2026, ranqueados por critérios reais de compra'
    }
  }[locale];
  const replaceText = (root=document.body) => {
    const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT, {acceptNode(node){
      if (!node.nodeValue || !node.nodeValue.trim()) return NodeFilter.FILTER_REJECT;
      if (node.parentElement && ['SCRIPT','STYLE','NOSCRIPT'].includes(node.parentElement.tagName)) return NodeFilter.FILTER_REJECT;
      return NodeFilter.FILTER_ACCEPT;
    }});
    const nodes=[]; while(walker.nextNode()) nodes.push(walker.currentNode);
    nodes.forEach(n => {
      const raw=n.nodeValue, trimmed=raw.trim();
      if(dict[trimmed]) n.nodeValue = raw.replace(trimmed, dict[trimmed]);
    });
  };
  function addBar(){
    const bar=document.createElement('div');
    bar.style.cssText='background:#0f172a;color:#fff;padding:8px 14px;font:13px Inter,system-ui,sans-serif;display:flex;gap:12px;justify-content:center;align-items:center;flex-wrap:wrap';
    bar.innerHTML='<span>'+dict.label+'</span><a href="?lang=en" style="color:#fff;text-decoration:underline">'+dict.keep+'</a><button type="button" style="background:#c2410c;color:#fff;border:0;border-radius:6px;padding:4px 10px;cursor:pointer">OK</button>';
    bar.querySelector('button').onclick=()=>bar.remove();
    bar.querySelector('a').onclick=()=>{localStorage.setItem('aict_lang','en')};
    document.body.prepend(bar);
  }
  if(document.readyState==='loading') document.addEventListener('DOMContentLoaded',()=>{replaceText();addBar();});
  else {replaceText();addBar();}
})();
</script>

</body>
</html>
